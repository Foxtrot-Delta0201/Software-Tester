# Copy this file to .env (in the repo root, alongside docker-compose.yml)
# and fill in your actual values.

FOCIMED_DB_HOST=localhost
FOCIMED_DB_PORT=5432
FOCIMED_DB_NAME=focimed_core
FOCIMED_SUPERUSER=postgres
POSTGRES_PASSWORD=focimed_local_secret
FOCIMED_APP_USER=app_user
FOCIMED_APP_PASSWORD=app_user_local_secret

# Absolute path to the harness root (used by the test runner to find pytest suites)
FOCI_PROJECT_DIR=C:/Users/kansa/Claude/Projects/Foci-Med harness
